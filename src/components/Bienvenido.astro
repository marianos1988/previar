---
import logo2 from '../assets/web/logo2.jpg';

const WELCOME_TITLE = "Bienvenido a Previar";

const WELCOME_SUBTITLE = "Tu distribuidora de bebidas Premium";

const WELCOME_DESCRIPTION = "Descubrí la mejor selección de bebidas Premium. Desde vinos selectos hasta cervezas, whiskeys importados y champagne. Calidad garantizada para tus momentos especiales.";

const BUTTON_TEXT = "Ver Catálogo";

const WELCOME_IMAGE = logo2.src;
---

<section class="welcome">
  <div class="welcome-bg"></div>
  <div class="welcome-accent-top"></div>
  <div class="welcome-accent-bottom"></div>
  <div class="bubbles">
    <span></span><span></span><span></span><span></span><span></span>
  </div>
  <div class="welcome-content">
    <div class="welcome-text">
      <span class="welcome-badge">Desde 2020</span>
      <h1 class="welcome-title">{WELCOME_TITLE}</h1>
      <p class="welcome-subtitle">{WELCOME_SUBTITLE}</p>
      <p class="welcome-description">{WELCOME_DESCRIPTION}</p>
      <a href="/tienda" class="welcome-btn">
        <span>{BUTTON_TEXT}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
    <div class="welcome-image">
      <div class="image-wrapper">
        <img src={WELCOME_IMAGE} alt="Previar - Bebidas Premium" />
        <div class="image-glow"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .welcome {
    position: relative;
    padding: 5rem 2rem;
    overflow: hidden;
  }

  .welcome-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #151515 100%);
    z-index: -1;
  }

  .welcome-accent-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.2), transparent);
    z-index: -1;
  }

  .welcome-accent-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
    z-index: -1;
  }

  .bubbles {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -1;
    overflow: hidden;
    opacity: 0.4;
  }

  .bubbles span {
    position: absolute;
    bottom: -50px;
    width: 6px;
    height: 6px;
    background: radial-gradient(circle at 30% 30%, rgba(212, 175, 55, 0.1), rgba(245, 166, 35, 0.02));
    border-radius: 50%;
    animation: rise 15s infinite linear;
  }

  .bubbles span:nth-child(1) { left: 10%; animation-delay: 0s; }
  .bubbles span:nth-child(2) { left: 25%; animation-delay: 3s; }
  .bubbles span:nth-child(3) { left: 50%; animation-delay: 6s; }
  .bubbles span:nth-child(4) { left: 75%; animation-delay: 9s; }
  .bubbles span:nth-child(5) { left: 90%; animation-delay: 12s; }

  @keyframes rise {
    0% { bottom: -50px; opacity: 0; }
    10% { opacity: 0.3; }
    50% { opacity: 0.2; }
    100% { bottom: 100%; opacity: 0; }
  }

  .welcome-content {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .welcome-text {
    animation: slideInLeft 0.8s ease-out;
  }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .welcome-badge {
    display: inline-block;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(245, 166, 35, 0.1) 100%);
    color: #d4af37;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    border: 1px solid rgba(212, 175, 55, 0.3);
  }

  .welcome-title {
    font-family: var(--font-title);
    font-size: 3rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1rem 0;
    line-height: 1.2;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: linear-gradient(180deg, #ffffff 0%, #d4af37 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .welcome-subtitle {
    font-family: var(--font-subtitle);
    font-size: 1.4rem;
    font-weight: 400;
    color: #c9a227;
    margin: 0 0 1.5rem 0;
    letter-spacing: 1px;
    font-style: italic;
  }

  .welcome-description {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.8;
    margin: 0 0 2rem 0;
    max-width: 500px;
  }

  .welcome-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: transparent;
    color: #d4af37;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 1rem 2rem;
    border-radius: 4px;
    border: 1px solid rgba(212, 175, 55, 0.5);
    transition: all 0.4s ease;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .welcome-btn svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .welcome-btn:hover {
    background: rgba(212, 175, 55, 0.15);
    border-color: #d4af37;
    transform: translateY(-2px);
    box-shadow: 0 5px 20px rgba(212, 175, 55, 0.2);
  }

  .welcome-btn:hover svg {
    transform: translateX(5px);
  }

  .welcome-image {
    position: relative;
    animation: slideInRight 0.8s ease-out;
  }

  @keyframes slideInRight {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .image-wrapper {
    position: relative;
    border-radius: 8px;
    overflow: visible;
    box-shadow: 
      0 25px 50px -12px rgba(0, 0, 0, 0.6),
      0 12px 24px -8px rgba(0, 0, 0, 0.4),
      0 0 80px -20px rgba(212, 175, 55, 0.15),
      0 0 30px -15px rgba(212, 175, 55, 0.1),
      inset 0 0 0 1px rgba(212, 175, 55, 0.08);
  }

  .image-wrapper::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.3), transparent 50%, rgba(245, 166, 35, 0.2));
    border-radius: 10px;
    z-index: -1;
    opacity: 0.5;
  }

  .image-wrapper img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.5s ease;
    border-radius: 6px;
  }

  .image-wrapper:hover img {
    transform: scale(1.03);
  }

  .image-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.1) 0%, transparent 50%, rgba(245, 166, 35, 0.05) 100%);
    pointer-events: none;
  }

  @media (max-width: 992px) {
    .welcome-content {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .welcome-title {
      font-size: 2.5rem;
    }

    .welcome-image {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .welcome {
      padding: 3rem 1.5rem;
    }

    .welcome-title {
      font-size: 2rem;
    }

    .welcome-subtitle {
      font-size: 1.2rem;
    }

    .welcome-description {
      font-size: 0.9rem;
    }

    .bubbles {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .welcome {
      padding: 2rem 1rem;
    }

    .welcome-title {
      font-size: 1.5rem;
    }

    .welcome-subtitle {
      font-size: 1rem;
    }

    .welcome-btn {
      padding: 0.85rem 1.5rem;
      font-size: 0.8rem;
    }
  }
</style>
