---
import { clientConfig } from "../config/clientConfig";
import msywebLogo from "../assets/footer/msyweb.png";

const logo = clientConfig.brand.logo;
const CLIENT_LOGO = logo?.src || logo;
const CLIENT_COMPANY_NAME = clientConfig.brand.name;
const CLIENT_SLOGAN = clientConfig.brand.slogan;

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-bg"></div>
  <div class="footer-accent-top"></div>
  <div class="footer-accent-bottom"></div>
  
  <div class="footer-top">
    <div class="footer-container">
      <div class="footer-section brand-section">
        <div class="brand-content">
          <img src={CLIENT_LOGO} alt={CLIENT_COMPANY_NAME} class="brand-logo" />
          <div class="brand-text">
            <h3 class="brand-name">{CLIENT_COMPANY_NAME}</h3>
            <p class="brand-tagline">{CLIENT_SLOGAN}</p>
          </div>
        </div>
      </div>

      <div class="footer-section">
        <h4 class="section-title">Enlaces</h4>
        <ul class="link-list">
          <li><a href="/" class="footer-link">Inicio</a></li>
          <li><a href="/tienda" class="footer-link">Tienda</a></li>
          <li><a href="/EnviosYPagos" class="footer-link">Envíos y pagos</a></li>
          <li><a href="/contacto" class="footer-link">Contacto</a></li>
        </ul>
      </div>

      <div class="footer-section">
        <h4 class="section-title">Contáctanos</h4>
        <ul class="contact-list">
          <li>
            <a href="https://www.google.com/maps/search/?api=1&query=Villa+del+Parque+CABA" target="_blank" rel="noopener noreferrer" class="contact-link">
              <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span>Zona Villa del Parque, C.A.B.A.</span>
            </a>
          </li>
          <li>
            <a href="https://wa.me/5491123233335" target="_blank" rel="noopener noreferrer" class="contact-link">
              <svg class="contact-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span>11 2323 3335</span>
            </a>
          </li>
          <li>
            <a href="mailto:previar.oficial@gmail.com" target="_blank" rel="noopener noreferrer" class="contact-link">
              <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
              <span>previar.oficial@gmail.com</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <p>© {year} <strong>{CLIENT_COMPANY_NAME}</strong> · Todos los derechos reservados</p>
    <a href="https://www.instagram.com/msy.web?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw==" target="_blank" rel="noopener noreferrer" class="msyweb-link">
      <span>Tienda creada por MSY WEB</span>
      <img src={msywebLogo.src} alt="MSY WEB" class="msyweb-logo" />
    </a>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    width: 100%;
  }

  .footer-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, #d4af37 0%, #f5a623 50%, #d4af37 100%);
    z-index: -2;
  }

  .footer-accent-top {
    display: none;
  }

  .footer-accent-bottom {
    display: none;
  }

  .footer-top {
    padding: 4rem 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: 4rem;
    padding: 0 1rem;
    box-sizing: border-box;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
  }

  .brand-section {
    position: relative;
  }

  .brand-content {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .brand-logo {
    height: 180px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(3px 3px 6px rgba(0, 0, 0, 0.5));
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    border-left: 2px solid #000000;
    padding-left: 1.5rem;
  }

  .brand-name {
    font-family: var(--font-title);
    font-size: 2.5rem;
    font-weight: 700;
    color: #000000;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin: 0;
  }

  .brand-tagline {
    font-family: var(--font-subtitle);
    font-size: 1.1rem;
    font-weight: 400;
    color: #1a1a1a;
    letter-spacing: 2px;
    margin: 0.5rem 0 0 0;
    text-transform: uppercase;
  }

  .brand-decoration {
    width: 60px;
    height: 2px;
    background: #000000;
    border-radius: 2px;
    margin-top: 1.5rem;
  }

  @media (max-width: 600px) {
    .brand-content {
      flex-direction: column;
      text-align: center;
    }

    .brand-logo {
      height: 50px;
    }

    .brand-decoration {
      margin: 1.5rem auto 0;
    }
  }

  .section-title {
    font-family: var(--font-title);
    font-size: 0.85rem;
    font-weight: 600;
    color: #000000;
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
  }

  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-link {
    font-family: var(--font-body);
    color: #1a1a1a;
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    display: inline-block;
    position: relative;
    padding: 0.25rem 0;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: #000000;
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .footer-link:hover {
    color: #000000;
  }

  .footer-link:hover::after {
    width: 60%;
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: #1a1a1a;
    line-height: 1.4;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: #1a1a1a;
    transition: all 0.3s ease;
    padding: 0.5rem;
    border-radius: 4px;
  }

  .contact-link:hover {
    color: #000000;
    background: rgba(0, 0, 0, 0.05);
    transform: translateX(5px);
  }

  .contact-link:hover .contact-icon {
    transform: scale(1.1);
  }

  .contact-icon {
    width: 20px;
    height: 20px;
    min-width: 20px;
    color: #000000;
    padding: 8px;
    background: rgba(0, 0, 0, 0.1);
    border-radius: 6px;
    transition: all 0.3s ease;
  }

  .contact-list li:hover .contact-icon {
    background: rgba(0, 0, 0, 0.2);
    transform: scale(1.1);
  }

  .footer-bottom {
    background: rgba(0, 0, 0, 0.15);
    padding: 1.5rem 2rem;
    text-align: center;
    width: 100%;
    box-sizing: border-box;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .footer-bottom p {
    font-family: var(--font-body);
    margin: 0;
    font-size: 0.85rem;
    color: #1a1a1a;
  }

  .footer-bottom strong {
    color: #000000;
  }

  .msyweb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    text-decoration: none;
    color: #000000;
    font-size: 0.8rem;
    transition: all 0.3s ease;
  }

  .msyweb-link:hover {
    color: #fffdd0;
  }

  .msyweb-logo {
    height: 28px;
    width: auto;
    object-fit: contain;
  }

  @media (max-width: 900px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
      padding: 0 1.5rem;
    }

    .brand-section {
      grid-column: 1 / -1;
    }

    .brand-content {
      flex-direction: row;
      justify-content: center;
      align-items: center;
    }

    .brand-logo {
      height: 100px;
    }

    .brand-text {
      border-left: 2px solid #000000;
      padding-left: 1.5rem;
      text-align: left;
    }

    .brand-name {
      font-size: 1.8rem;
    }

    .brand-tagline {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 600px) {
    .footer-top {
      padding: 3rem 1rem;
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 0 1rem;
      text-align: center;
    }

    .brand-content {
      flex-direction: column;
    }

    .brand-logo {
      height: 80px;
    }

    .brand-text {
      border-left: none;
      padding-left: 0;
      border-top: 2px solid #000000;
      padding-top: 1rem;
      text-align: center;
    }

    .section-title {
      text-align: center;
    }

    .link-list {
      align-items: center;
    }

    .contact-list {
      align-items: center;
    }

    .contact-list li {
      justify-content: center;
    }
  }
</style>
