---
// ====================================================
// CONFIGURACIÓN CENTRALIZADA
// Todos los datos del cliente están en src/config/clientConfig.js
// ====================================================
import { clientConfig } from "../config/clientConfig";

const CLIENT_LOGO = clientConfig.brand.logo;
const CLIENT_COMPANY_NAME = clientConfig.brand.name;
const CLIENT_SLOGAN = clientConfig.brand.slogan;
const SHOP_ADDRESS = clientConfig.contact.address;
const SHOP_PHONE = clientConfig.contact.phone;
const SHOP_EMAIL = clientConfig.contact.email;
const WHATSAPP_DISPLAY = clientConfig.whatsapp.number 
  ? `+${clientConfig.whatsapp.number.slice(0, 2)} ${clientConfig.whatsapp.number.slice(2)}`
  : 'Sin configurar';
// ====================================================

const year = new Date().getFullYear();
---

<footer class="footer">
  <!-- Sección Principal -->
  <div class="footer-top">
    <div class="footer-container">
      <!-- Marca -->
      <div class="footer-section brand-section">
        <div class="brand-logo">{CLIENT_LOGO}</div>
        <h3 class="brand-name">{CLIENT_COMPANY_NAME}</h3>
        <p class="brand-tagline">{CLIENT_SLOGAN}</p>
        <div class="brand-decoration"></div>
      </div>

      <!-- Navegación -->
      <div class="footer-section">
        <h4 class="section-title">Enlaces</h4>
        <ul class="link-list">
          <li><a href="/" class="footer-link">Inicio</a></li>
          <li><a href="/tienda" class="footer-link">Tienda</a></li>
          <li><a href="/contacto" class="footer-link">Contacto</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div class="footer-section">
        <h4 class="section-title">Contáctanos</h4>
        <ul class="contact-list">
          <li>
            <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>{SHOP_ADDRESS}</span>
          </li>
          <li>
            <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
            <span>{SHOP_PHONE}</span>
          </li>
          <li>
            <svg class="contact-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            <span>{WHATSAPP_DISPLAY}</span>
          </li>
          <li>
            <svg class="contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            <span>{SHOP_EMAIL}</span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Copyright -->
  <div class="footer-bottom">
    <p>© {year} <strong>{CLIENT_COMPANY_NAME}</strong> · Todos los derechos reservados</p>
  </div>
</footer>

<style>
  .footer {
    background: #2d2d44;
    color: #e8e8e8;
    width: 100%;
  }

  /* Top Section */
  .footer-top {
    padding: 3rem 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .footer-container {
    max-width: 100%;
    width: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    padding: 0 2rem;
    box-sizing: border-box;
  }

  .footer-section {
    display: flex;
    flex-direction: column;
  }

  /* Brand Section */
  .brand-section {
    position: relative;
  }

  .brand-logo {
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
  }

  .brand-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem 0;
    letter-spacing: 1px;
  }

  .brand-tagline {
    font-family: 'Lora', Georgia, serif;
    font-size: 1rem;
    color: #a0a0b0;
    margin: 0;
    font-style: italic;
  }

  .brand-decoration {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #667eea, #764ba2);
    border-radius: 2px;
    margin-top: 1.5rem;
  }

  /* Section Title */
  .section-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 1.5rem 0;
    text-transform: uppercase;
    letter-spacing: 3px;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #4a4a6a;
  }

  /* Link List */
  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-link {
    font-family: 'Lora', Georgia, serif;
    color: #b0b0c0;
    text-decoration: none;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    display: inline-block;
    position: relative;
    padding: 0.25rem 0;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: #667eea;
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .footer-link:hover {
    color: #667eea;
  }

  .footer-link:hover::after {
    width: 100%;
  }

  /* Contact List */
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: 'Lora', Georgia, serif;
    font-size: 0.9rem;
    color: #b0b0c0;
    line-height: 1.4;
  }

  .contact-icon {
    width: 22px;
    height: 22px;
    min-width: 22px;
    color: #667eea;
    padding: 6px;
    background: rgba(102, 126, 234, 0.1);
    border-radius: 8px;
    transition: all 0.3s ease;
  }

  .contact-list li:hover .contact-icon {
    background: rgba(102, 126, 234, 0.2);
    transform: scale(1.1);
  }

  /* Bottom */
  .footer-bottom {
    background: #1f1f30;
    padding: 1.5rem 2rem;
    text-align: center;
    width: 100%;
    box-sizing: border-box;
  }

  .footer-bottom p {
    font-family: 'Lora', Georgia, serif;
    margin: 0;
    font-size: 0.85rem;
    color: #707090;
  }

  .footer-bottom strong {
    color: #a0a0b0;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .footer-container {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      padding: 0 1.5rem;
    }

    .brand-section {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 600px) {
    .footer-top {
      padding: 2rem 1rem;
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 0 1rem;
      text-align: center;
    }

    .brand-logo {
      font-size: 3rem;
    }

    .brand-decoration {
      margin: 1.5rem auto 0;
    }

    .section-title {
      text-align: center;
      border-bottom: none;
    }

    .link-list {
      align-items: center;
    }

    .contact-list {
      align-items: center;
    }

    .contact-list li {
      justify-content: center;
    }
  }
</style>