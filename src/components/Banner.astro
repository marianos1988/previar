---
import slide1 from '../assets/carousel/1.jpg';
import slide2 from '../assets/carousel/2.jpg';
import slide3 from '../assets/carousel/3.jpg';
import slide4 from '../assets/carousel/4.jpg';
import slide5 from '../assets/carousel/5.jpg';

const BANNER_SLIDES = [
  {
    image: slide1.src,
    title: "Distribuidora de Bebidas",
    subtitle: "Tu proveedor oficial de las mejores bebidas"
  },
  {
    image: slide2.src,
    title: "Envíos a a domicilio",
    subtitle: "Consultanos sobre envíos y entrega a tu zona"
  },
  {
    image: slide3.src,
    title: "Venta Mayorista de Bebidas",
    subtitle: "Abastece tus eventos y celebraciones con las mejores bebidas"
  },
  {
    image: slide4.src,
    title: "Calidad, Variedad y Sabor",
    subtitle: "Las mejores bebidas Premium para los paladares más exigentes"
  },
  {
    image: slide5.src,
    title: "Combos de Bebidas",
    subtitle: "Paquetes especiales para vos y tu familia"
  }
];
---

<div class="banner-slider">
  <div class="slider-container" id="sliderContainer">
    {BANNER_SLIDES.map((slide, index: number) => (
      <div class="slide" data-index={index}>
        <img src={slide.image} alt={slide.title} class="slide-image" />
        <div class="slide-content">
          <h2 class="slide-title">{slide.title}</h2>
          <p class="slide-subtitle">{slide.subtitle}</p>
        </div>
      </div>
    ))}
  </div>

  <button class="nav-btn prev-btn" id="prevBtn" aria-label="Imagen anterior">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button class="nav-btn next-btn" id="nextBtn" aria-label="Siguiente imagen">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>

  <div class="dots" id="dots">
    {BANNER_SLIDES.map((_: any, index: number) => (
      <button class="dot" data-index={index} aria-label={`Ir a imagen ${index + 1}`}></button>
    ))}
  </div>
</div>

<script>
  const container = document.getElementById('sliderContainer') as HTMLElement | null;
  const slides = document.querySelectorAll('.slide') as NodeListOf<HTMLElement>;
  const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement | null;
  const dots = document.querySelectorAll('.dot') as NodeListOf<HTMLButtonElement>;
  
  let currentIndex = 0;
  const totalSlides = slides.length;

  function updateSlider() {
    if (!container) return;
    container.style.transform = `translateX(-${currentIndex * 100}%)`;
    
    dots.forEach((dot, index) => {
      dot.classList.toggle('active', index === currentIndex);
    });

    slides.forEach((slide, index) => {
      slide.classList.toggle('active', index === currentIndex);
    });
  }

  function nextSlide() {
    currentIndex = (currentIndex + 1) % totalSlides;
    updateSlider();
  }

  function prevSlide() {
    currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
    updateSlider();
  }

  nextBtn?.addEventListener('click', nextSlide);
  prevBtn?.addEventListener('click', prevSlide);

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      currentIndex = parseInt(dot.getAttribute('data-index') || '0');
      updateSlider();
    });
  });

  updateSlider();
</script>

<style>
  .banner-slider {
    position: relative;
    width: 100%;
    height: 500px;
    overflow: hidden;
    background: #0d0d0d;
  }

  .slider-container {
    display: flex;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    height: 100%;
  }

  .slide {
    min-width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .slide-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 4rem 2rem;
    background: linear-gradient(to top, rgba(13, 13, 13, 0.95) 0%, rgba(13, 13, 13, 0.7) 40%, transparent 100%);
    text-align: center;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.6s ease;
  }

  .slide-title {
    font-family: var(--font-title);
    font-size: 2.5rem;
    color: #fff;
    margin: 0 0 0.75rem 0;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
    letter-spacing: 3px;
    text-transform: uppercase;
    transform: translateY(20px);
    transition: transform 0.6s ease;
  }

  .slide-subtitle {
    font-family: var(--font-subtitle);
    font-size: 1.2rem;
    color: rgba(212, 175, 55, 0.9);
    margin: 0;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
    letter-spacing: 1px;
    transform: translateY(20px);
    transition: transform 0.6s ease 0.1s;
  }

  .slide.active .slide-content {
    opacity: 1;
    transform: translateY(0);
  }

  .slide.active .slide-title {
    transform: translateY(0);
  }

  .slide.active .slide-subtitle {
    transform: translateY(0);
  }

  .nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    background: rgba(13, 13, 13, 0.6);
    border: 1px solid rgba(212, 175, 55, 0.3);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(10px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 10;
  }

  .nav-btn svg {
    width: 20px;
    height: 20px;
    color: #d4af37;
    transition: all 0.3s ease;
  }

  .nav-btn:hover {
    background: rgba(212, 175, 55, 0.2);
    border-color: #d4af37;
    transform: translateY(-50%) scale(1.1);
  }

  .nav-btn:hover svg {
    color: #f5a623;
  }

  .prev-btn:hover svg {
    transform: translateX(-2px);
  }

  .next-btn:hover svg {
    transform: translateX(2px);
  }

  .prev-btn {
    left: 20px;
  }

  .next-btn {
    right: 20px;
  }

  .dots {
    position: absolute;
    bottom: 25px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 12px;
    z-index: 10;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(212, 175, 55, 0.3);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: #d4af37;
    border-color: #d4af37;
    transform: scale(1.3);
  }

  .dot:hover:not(.active) {
    background: rgba(212, 175, 55, 0.5);
    border-color: rgba(212, 175, 55, 0.5);
  }

  @media (max-width: 768px) {
    .banner-slider {
      height: 50vh;
      min-height: 280px;
      max-height: 400px;
      background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 100%);
    }

    .slide-image {
      object-fit: contain;
      object-position: center;
      background: transparent;
    }

    .slide-content {
      padding: 2.5rem 1.5rem;
    }

    .slide-title {
      font-size: 1.6rem;
    }

    .slide-subtitle {
      font-size: 1rem;
    }

    .nav-btn {
      width: 40px;
      height: 40px;
    }

    .nav-btn svg {
      width: 18px;
      height: 18px;
    }

    .prev-btn {
      left: 10px;
    }

    .next-btn {
      right: 10px;
    }

    .dots {
      bottom: 15px;
    }

    .dot {
      width: 8px;
      height: 8px;
    }
  }

  @media (max-width: 480px) {
    .banner-slider {
      height: 45vh;
      min-height: 200px;
      max-height: 320px;
      background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 100%);
    }

    .slide-image {
      object-fit: contain;
      object-position: center;
    }

    .slide-title {
      font-size: 1.25rem;
    }

    .slide-subtitle {
      font-size: 0.85rem;
    }

    .nav-btn {
      width: 34px;
      height: 34px;
    }

    .nav-btn svg {
      width: 16px;
      height: 16px;
    }
  }



</style>
