---
import { clientConfig } from "../config/clientConfig";

const logo = clientConfig.brand.logo;
const CLIENT_LOGO = logo?.src || logo;
---

<nav class="navbar" id="mainNavbar">
  <div class="nav-bg"></div>
  <div class="nav-accent-top"></div>
  <div class="nav-accent-bottom"></div>
  <div class="nav-logo" id="navLogo">
    <a href="/"><img src={CLIENT_LOGO} alt="Previar" class="logo-img" /></a>
  </div>
  <button class="menu-toggle" id="menuToggle" aria-label="Menú">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
  <div class="nav-overlay" id="navOverlay"></div>
  <div class="nav-links" id="navLinks">
    <div class="nav-header">
      <div class="mobile-logo">
        <img src={CLIENT_LOGO} alt="Previar" class="mobile-logo-img" />
      </div>
      <button class="close-btn" id="closeBtn" aria-label="Cerrar">&times;</button>
    </div>
    <a href="/" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <span class="nav-text">Inicio</span>
    </a>
    <a href="/tienda" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      <span class="nav-text">Tienda</span>
    </a>
    <a href="/EnviosYPagos" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="1" y="3" width="15" height="13"></rect>
        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
        <circle cx="5.5" cy="18.5" r="2.5"></circle>
        <circle cx="18.5" cy="18.5" r="2.5"></circle>
      </svg>
      <span class="nav-text">Envíos y pagos</span>
    </a>
    <a href="/contacto" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      <span class="nav-text">Contacto</span>
    </a>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const navLinks = document.getElementById('navLinks');
  const navOverlay = document.getElementById('navOverlay');
  const closeBtn = document.getElementById('closeBtn');
  const navLogo = document.getElementById('navLogo');

  function openMenu() {
    navLinks?.classList.add('active');
    navOverlay?.classList.add('active');
    menuToggle?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    navLinks?.classList.remove('active');
    navOverlay?.classList.remove('active');
    menuToggle?.classList.remove('active');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  navOverlay?.addEventListener('click', closeMenu);

  let lastScroll = 0;
  const navbar = document.getElementById('mainNavbar');
  const footer = document.querySelector('footer');

  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    const footerRect = footer?.getBoundingClientRect();
    const isFooterVisible = footerRect && footerRect.top < window.innerHeight;
    
    if (currentScroll > 50) {
      navLogo?.classList.add('visible');
    } else {
      navLogo?.classList.remove('visible');
    }

    if (isFooterVisible) {
      navbar?.classList.add('hidden');
    } else {
      navbar?.classList.remove('hidden');
    }
    
    lastScroll = currentScroll;
  });
</script>

<style>
  .navbar {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    min-height: 70px;
    overflow: hidden;
    transition: transform 0.4s ease;
  }

  .navbar.hidden {
    transform: translateY(-100%);
  }

  .nav-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, rgba(13, 13, 13, 0.95) 0%, rgba(26, 26, 26, 0.95) 100%);
    backdrop-filter: blur(10px);
    z-index: -2;
  }

  .nav-accent-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
    z-index: -1;
  }

  .nav-accent-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.5), transparent);
    z-index: -1;
  }

  .nav-logo {
    display: none;
    align-items: center;
    position: absolute;
    left: 2rem;
  }

  .nav-logo.visible {
    display: flex;
  }

  .nav-logo .logo-img {
    height: 32px;
    width: auto;
    object-fit: contain;
    opacity: 0.9;
  }
  
  .nav-logo a {
    display: block;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    transition: all 0.3s ease;
    position: absolute;
    right: 1.5rem;
  }

  .menu-toggle:hover .bar {
    background: #f5a623;
  }

  .bar {
    width: 24px;
    height: 1.5px;
    background: rgba(212, 175, 55, 0.7);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .bar:not(:last-child) {
    margin-bottom: 6px;
  }

  .nav-links {
    display: flex;
    gap: 0.25rem;
    align-items: center;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    transition: all 0.4s ease;
    padding: 0.75rem 1.25rem;
    position: relative;
  }

  .nav-icon {
    display: block;
    width: 16px;
    height: 16px;
    stroke: rgba(212, 175, 55, 0.6);
    transition: all 0.4s ease;
  }

  .nav-item::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
    transition: all 0.4s ease;
    transform: translateX(-50%);
  }

  .nav-item:hover {
    color: rgba(255, 255, 255, 0.95);
    background: rgba(212, 175, 55, 0.05);
  }

  .nav-item:hover::before {
    width: 70%;
  }

  .nav-item:hover .nav-icon {
    stroke: #d4af37;
    transform: scale(1.1);
  }

  .nav-header {
    display: none;
  }

  @media (max-width: 768px) {
    .navbar {
      padding: 0;
      min-height: 60px;
    }

    .nav-logo {
      display: none;
      align-items: center;
      position: absolute;
      left: 1rem;
    }

    .nav-logo.visible {
      display: flex;
    }

    .menu-toggle {
      display: flex;
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
    }

    .nav-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.85);
      backdrop-filter: blur(8px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.4s ease;
      z-index: 1002;
    }

    .nav-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: -300px;
      width: 300px;
      height: 100vh;
      background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 100%);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0;
      box-shadow: -10px 0 40px rgba(0, 0, 0, 0.5);
      transition: right 0.5s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1003;
      overflow-y: auto;
    }

    .nav-links.active {
      right: 0;
    }

    .nav-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.5rem;
      border-bottom: 1px solid rgba(212, 175, 55, 0.15);
    }

    .mobile-logo {
      display: flex;
      align-items: center;
    }

    .mobile-logo-img {
      height: 45px;
      width: auto;
      object-fit: contain;
      filter: drop-shadow(0 2px 8px rgba(212, 175, 55, 0.3));
    }

    .close-btn {
      background: transparent;
      border: 1px solid rgba(212, 175, 55, 0.3);
      font-size: 1.5rem;
      color: #d4af37;
      cursor: pointer;
      padding: 0.5rem 0.8rem;
      line-height: 1;
      border-radius: 4px;
      transition: all 0.3s ease;
    }

    .close-btn:hover {
      background: rgba(212, 175, 55, 0.15);
      border-color: #d4af37;
    }

    .nav-item {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 1rem;
      padding: 1.5rem 2rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.03);
      transition: all 0.4s ease;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.85rem;
    }

    .nav-item:hover {
      background: rgba(212, 175, 55, 0.08);
      color: rgba(255, 255, 255, 0.95);
      padding-left: 2.5rem;
    }

    .nav-icon {
      width: 20px;
      height: 20px;
      display: block;
      stroke: rgba(212, 175, 55, 0.5);
    }

    .nav-text {
      font-size: 0.9rem;
      font-weight: 400;
      letter-spacing: 2px;
    }

    .nav-item:hover .nav-icon {
      stroke: #d4af37;
    }

    .menu-toggle.active .bar:nth-child(1) {
      transform: translateY(7.5px) rotate(45deg);
      background: #d4af37;
    }

    .menu-toggle.active .bar:nth-child(2) {
      opacity: 0;
    }

    .menu-toggle.active .bar:nth-child(3) {
      transform: translateY(-7.5px) rotate(-45deg);
      background: #d4af37;
    }
  }

  @media (max-width: 480px) {
    .nav-item {
      padding: 1.25rem 1.5rem;
      font-size: 0.8rem;
    }
  }
</style>
