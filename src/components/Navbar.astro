---
// ====================================================
// CONFIGURACIÓN CENTRALIZADA
// Todos los datos del cliente están en src/config/clientConfig.js
// ====================================================
import { clientConfig } from "../config/clientConfig";

const CLIENT_LOGO = clientConfig.brand.logo;
// ====================================================
---

<nav class="navbar" id="mainNavbar">
  <div class="nav-bg"></div>
  <div class="candy-pattern"></div>
  <div class="nav-logo" id="navLogo">
    <span class="logo">{CLIENT_LOGO}</span>
  </div>
  <button class="menu-toggle" id="menuToggle" aria-label="Menú">
    <span class="bar"></span>
    <span class="bar"></span>
    <span class="bar"></span>
  </button>
  <div class="nav-overlay" id="navOverlay"></div>
  <div class="nav-links" id="navLinks">
    <div class="nav-header">
      <button class="close-btn" id="closeBtn" aria-label="Cerrar">&times;</button>
    </div>
    <a href="/" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
      <span class="nav-text">Inicio</span>
    </a>
    <a href="/tienda" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <path d="M16 10a4 4 0 0 1-8 0"></path>
      </svg>
      <span class="nav-text">Tienda</span>
    </a>
    <a href="/contacto" class="nav-item">
      <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      <span class="nav-text">Contacto</span>
    </a>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const navLinks = document.getElementById('navLinks');
  const navOverlay = document.getElementById('navOverlay');
  const closeBtn = document.getElementById('closeBtn');
  const navLogo = document.getElementById('navLogo');
  const mainNavbar = document.getElementById('mainNavbar');

  function openMenu() {
    navLinks?.classList.add('active');
    navOverlay?.classList.add('active');
    menuToggle?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    navLinks?.classList.remove('active');
    navOverlay?.classList.remove('active');
    menuToggle?.classList.remove('active');
    document.body.style.overflow = '';
  }

  menuToggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  navOverlay?.addEventListener('click', closeMenu);

  // Scroll detection - mostrar logo cuando se hace scroll
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    
    if (currentScroll > 50) {
      navLogo?.classList.add('visible');
    } else {
      navLogo?.classList.remove('visible');
    }
    
    lastScroll = currentScroll;
  });
</script>

<style>
  .navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    position: sticky;
    top: 0;
    z-index: 1000;
    min-height: 60px;
    overflow: hidden;
  }

  .nav-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, #fff5f5 0%, #ffe4e8 50%, #fff0f5 100%);
    z-index: -2;
  }

  .candy-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -1;
    opacity: 0.3;
    background-image: 
      radial-gradient(circle at 10% 20%, #ffb6c1 2px, transparent 2px),
      radial-gradient(circle at 90% 80%, #ffb6c1 2px, transparent 2px),
      radial-gradient(circle at 30% 70%, #ffd4e5 2px, transparent 2px),
      radial-gradient(circle at 70% 30%, #ffd4e5 2px, transparent 2px),
      radial-gradient(circle at 50% 50%, #ff9ecd 1.5px, transparent 1.5px);
    background-size: 60px 60px, 80px 80px, 50px 50px, 70px 70px, 40px 40px;
  }

  .nav-logo {
    display: none;
    align-items: center;
    position: absolute;
    left: 1rem;
  }

  .nav-logo.visible {
    display: flex;
  }

  .nav-logo .logo {
    font-size: 1.5rem;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 8px;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    transition: all 0.3s ease;
  }

  .menu-toggle:hover {
    background: rgba(255, 255, 255, 0.5);
  }

  .bar {
    width: 20px;
    height: 2px;
    background: #4a2c2a;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .bar:not(:last-child) {
    margin-bottom: 4px;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    margin: 0 auto;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: #4a2c2a;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s ease;
    padding: 0.5rem 1rem;
    position: relative;
    border-radius: 20px;
  }

  .nav-icon {
    display: block;
    width: 20px;
    height: 20px;
    stroke: #4a2c2a;
  }

  .nav-item::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: #c74b7a;
    transition: all 0.3s ease;
    transform: translateX(-50%);
  }

  .nav-item:hover {
    color: #c74b7a;
    background: rgba(255, 255, 255, 0.2);
  }

  .nav-item:hover::after {
    width: 100%;
  }

  .nav-item:hover .nav-icon {
    stroke: #c74b7a;
  }

  .nav-header {
    display: none;
  }

  /* MOBILE (< 768px) */
  @media (max-width: 768px) {
    .navbar {
      padding: 0.75rem 1rem;
      min-height: 56px;
    }

    .nav-logo {
      display: none;
      align-items: center;
    }

    .nav-logo.visible {
      display: flex;
    }

    .menu-toggle {
      display: flex;
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
    }

    .nav-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(255, 154, 158, 0.5);
      backdrop-filter: blur(4px);
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      z-index: 1002;
    }

    .nav-overlay.active {
      opacity: 1;
      visibility: visible;
    }

    .nav-links {
      position: fixed;
      top: 0;
      right: -280px;
      width: 280px;
      height: 100vh;
      background: linear-gradient(135deg, #fff5f5 0%, #ffe4e8 50%, #fff0f5 100%);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0;
      box-shadow: -4px 0 20px rgba(0, 0, 0, 0.15);
      transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      z-index: 1003;
      overflow-y: auto;
    }

    .nav-links.active {
      right: 0;
    }

    .nav-header {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      padding: 1.25rem 1.5rem;
    }

    .close-btn {
      background: rgba(255, 255, 255, 0.3);
      border: none;
      font-size: 1.75rem;
      color: #4a2c2a;
      cursor: pointer;
      padding: 0.5rem;
      line-height: 1;
      border-radius: 50%;
      transition: all 0.2s ease;
    }

    .close-btn:hover {
      background: rgba(255, 255, 255, 0.5);
      transform: scale(1.1);
    }

    .nav-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      transition: all 0.3s ease;
      color: #4a2c2a;
    }

    .nav-item:hover {
      background: rgba(255, 255, 255, 0.3);
      padding-left: 2rem;
    }

    .nav-icon {
      width: 24px;
      height: 24px;
      display: block;
      stroke: #4a2c2a;
    }

    .nav-text {
      font-size: 1rem;
      font-weight: 500;
      color: #4a2c2a;
    }

    .nav-item:hover .nav-icon {
      stroke: #c74b7a;
    }

    /* Animación burger a X */
    .menu-toggle.active .bar:nth-child(1) {
      transform: translateY(6px) rotate(45deg);
    }

    .menu-toggle.active .bar:nth-child(2) {
      opacity: 0;
    }

    .menu-toggle.active .bar:nth-child(3) {
      transform: translateY(-6px) rotate(-45deg);
    }
  }
</style>