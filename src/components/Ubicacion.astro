---
const DIRECCION = "Zona Villa del Parque, C.A.B.A.";
const TELEFONO = "1123233335";
const HORARIO = "Lunes a sábados de 10 a 22hs";

const GOOGLE_MAPS_URL = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.219202379436!2d-58.48326568477135!3d-34.60372298029068!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4aa9f59b2f0a1f1f%3A0x1f1f1f1f1f1f1f1f!2sVilla%20del%20Parque%2C%20CABA!5e0!3m2!1ses!2sar!4v1700000000000!5m2!1ses!2sar";
---

<section class="ubicacion">
  <div class="ubicacion-bg"></div>
  <div class="ubicacion-accent-top"></div>
  <div class="ubicacion-accent-bottom"></div>
  <div class="container">
    <div class="section-header">
      <span class="section-tag">¡Visítanos!</span>
      <h2 class="section-title">Nuestra Ubicación</h2>
      <div class="section-line"></div>
      <p class="section-subtitle">Te esperamos en nuestro local</p>
    </div>

    <div class="ubicacion-wrapper">
      <div class="ubicacion-main">
        <div class="mapa-frame">
          <div class="mapa-inner">
            <iframe 
              src={GOOGLE_MAPS_URL}
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de la tienda"
            ></iframe>
          </div>
          <div class="mapa-glow"></div>
        </div>
      </div>

      <div class="ubicacion-details">
        <div class="detail-card">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Dirección</h3>
            <p>{DIRECCION}</p>
          </div>
        </div>

        <div class="detail-card">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Horario</h3>
            <p>{HORARIO}</p>
          </div>
        </div>

        <div class="detail-card">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Teléfono</h3>
            <p>{TELEFONO}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ubicacion {
    position: relative;
    padding: 5rem 2rem;
    overflow: hidden;
  }

  .ubicacion-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, #0d0d0d 0%, #151515 50%, #0d0d0d 100%);
    z-index: -1;
  }

  .ubicacion-accent-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.2), transparent);
    z-index: -1;
  }

  .ubicacion-accent-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
    z-index: -1;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: #c9a227;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-title);
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1rem 0;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .section-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, #d4af37, #f5a623);
    margin: 0 auto;
    border-radius: 2px;
  }

  .section-subtitle {
    font-family: var(--font-subtitle);
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 1rem 0 0 0;
    font-style: italic;
  }

  .ubicacion-wrapper {
    display: flex;
    gap: 2.5rem;
    align-items: stretch;
  }

  .ubicacion-main {
    flex: 0 0 55%;
  }

  .mapa-frame {
    position: relative;
    height: 380px;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(212, 175, 55, 0.08);
    border: 1px solid rgba(212, 175, 55, 0.1);
  }

  .mapa-inner {
    width: 100%;
    height: 100%;
  }

  .mapa-inner iframe {
    width: 100%;
    height: 100%;
    filter: grayscale(30%) contrast(1.1) brightness(0.9);
  }

  .mapa-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.05) 0%, transparent 50%, rgba(245, 166, 35, 0.03) 100%);
    pointer-events: none;
  }

  .ubicacion-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .detail-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.8) 0%, rgba(13, 13, 13, 0.9) 100%);
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.08);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s ease;
  }

  .detail-card:hover {
    transform: translateY(-3px);
    border-color: rgba(212, 175, 55, 0.2);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(212, 175, 55, 0.1);
  }

  .detail-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(245, 166, 35, 0.1) 100%);
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid rgba(212, 175, 55, 0.2);
  }

  .detail-icon svg {
    width: 22px;
    height: 22px;
    color: #d4af37;
  }

  .detail-content h3 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: #c9a227;
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .detail-content p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .ubicacion-wrapper {
      flex-direction: column;
    }

    .ubicacion-main {
      flex: none;
    }

    .mapa-frame {
      height: 300px;
    }
  }

  @media (max-width: 600px) {
    .ubicacion {
      padding: 3rem 1rem;
    }

    .section-title {
      font-size: 1.8rem;
    }

    .mapa-frame {
      height: 250px;
      border-radius: 6px;
    }

    .detail-card {
      padding: 1.25rem;
    }

    .detail-icon {
      width: 40px;
      height: 40px;
    }

    .detail-icon svg {
      width: 18px;
      height: 18px;
    }

    .detail-content h3 {
      font-size: 0.7rem;
    }

    .detail-content p {
      font-size: 0.85rem;
    }
  }
</style>
