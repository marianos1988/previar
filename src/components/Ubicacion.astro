---
// ====================================================
// CONFIGURACIÓN DEL CLIENTE - EDITAR AQUÍ
// ====================================================

// DIRECCIÓN DE LA TIENDA
const DIRECCION = "Av. Corrientes 1234, Ciudad Autónoma de Buenos Aires, Argentina";

// CIUDAD
const CIUDAD = "Buenos Aires";

// PROVINCIA
const PROVINCIA = "Ciudad Autónoma de Buenos Aires";

// PAÍS
const PAIS = "Argentina";

// URL DE GOOGLE MAPS (embed) - Puedes usar la URL de tu ubicación específica
const GOOGLE_MAPS_URL = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.219202379436!2d-58.38326568477135!3d-34.60372298029068!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4aa9f59b2f0a1f1f%3A0x1f1f1f1f1f1f1f1f!2sAv.%20Corrientes%201234%2C%20C1043%20CABA!5e0!3m2!1ses!2sar!4v1700000000000!5m2!1ses!2sar";

// ====================================================
---

<section class="ubicacion">
  <div class="ubicacion-bg"></div>
  <div class="container">
    <div class="section-header">
      <span class="section-tag">¡Visítanos!</span>
      <h2 class="section-title">Nuestra Ubicación</h2>
      <div class="section-line"></div>
      <p class="section-subtitle">Te esperamos en nuestro local</p>
    </div>

    <div class="ubicacion-wrapper">
      <div class="ubicacion-main">
        <div class="mapa-frame">
          <div class="mapa-inner">
            <iframe 
              src={GOOGLE_MAPS_URL}
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de la tienda"
            ></iframe>
          </div>
          <div class="mapa-overlay"></div>
        </div>
      </div>

      <div class="ubicacion-details">
        <div class="detail-card location">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Dirección</h3>
            <p>{DIRECCION}</p>
          </div>
        </div>

        <div class="detail-card city">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Ciudad</h3>
            <p>{PROVINCIA}, {PAIS}</p>
          </div>
        </div>

        <div class="detail-card schedule">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Horario</h3>
            <p>Lun - Sáb: 9:00 a 21:00</p>
            <p>Dom: 10:00 a 18:00</p>
          </div>
        </div>

        <div class="detail-card phone">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Teléfono</h3>
            <p>+54 11 1234-5678</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ubicacion {
    position: relative;
    padding: 4rem 2rem;
    overflow: hidden;
  }

  .ubicacion-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, #fff5f8 0%, #fff0f5 50%, #ffeef2 100%);
    z-index: -1;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .section-tag {
    display: inline-block;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: #c74b7a;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #4a2c2a;
    margin: 0 0 0.75rem 0;
  }

  .section-line {
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, #ff6b9d, #c74b7a);
    margin: 0 auto;
    border-radius: 2px;
  }

  .section-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 1rem;
    color: #8b6b7a;
    margin: 1rem 0 0 0;
  }

  .ubicacion-wrapper {
    display: flex;
    gap: 2rem;
    align-items: stretch;
  }

  .ubicacion-main {
    flex: 0 0 55%;
  }

  .mapa-frame {
    position: relative;
    height: 320px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(199, 75, 122, 0.18);
  }

  .mapa-inner {
    width: 100%;
    height: 100%;
  }

  .mapa-inner iframe {
    width: 100%;
    height: 100%;
    filter: grayscale(20%) contrast(1.05);
  }

  .mapa-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    border-radius: 16px;
    box-shadow: inset 0 0 0 3px rgba(255, 255, 255, 0.5);
  }

  .ubicacion-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .detail-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(199, 75, 122, 0.08);
    transition: all 0.3s ease;
  }

  .detail-card:hover {
    transform: translateX(5px);
    box-shadow: 0 6px 20px rgba(199, 75, 122, 0.12);
  }

  .detail-icon {
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #ff8fb3 0%, #c74b7a 100%);
    border-radius: 10px;
    flex-shrink: 0;
  }

  .detail-icon svg {
    width: 20px;
    height: 20px;
    color: white;
  }

  .detail-content h3 {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    color: #c74b7a;
    margin: 0 0 0.25rem 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .detail-content p {
    font-family: 'Lora', serif;
    font-size: 0.9rem;
    color: #5a404a;
    margin: 0;
    line-height: 1.4;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .ubicacion-wrapper {
      flex-direction: column;
    }

    .ubicacion-main {
      flex: none;
    }

    .mapa-frame {
      height: 280px;
    }
  }

  @media (max-width: 600px) {
    .ubicacion {
      padding: 3rem 1rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .mapa-frame {
      height: 250px;
      border-radius: 12px;
    }

    .detail-card {
      padding: 0.85rem 1rem;
    }

    .detail-icon {
      width: 36px;
      height: 36px;
    }

    .detail-icon svg {
      width: 18px;
      height: 18px;
    }

    .detail-content h3 {
      font-size: 0.75rem;
    }

    .detail-content p {
      font-size: 0.85rem;
    }
  }
</style>