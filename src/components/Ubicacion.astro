---
const DIRECCION = "Zona Villa del Parque, C.A.B.A.";
const TELEFONO = "1123233335";
const HORARIO = "Lunes a sábados de 10 a 22hs";

const GOOGLE_MAPS_URL = "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3284.219202379436!2d-58.48326568477135!3d-34.60372298029068!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4aa9f59b2f0a1f1f%3A0x1f1f1f1f1f1f1f1f!2sVilla%20del%20Parque%2C%20CABA!5e0!3m2!1ses!2sar!4v1700000000000!5m2!1ses!2sar";

const whatsappOptions = [
  { number: "5491130552110", label: "1130552110 - Alejandro" },
  { number: "5491123233335", label: "1123233335 - Mariano" },
  { number: "5491123961837", label: "1123961837 - Diego" }
];
---

<section class="ubicacion">
  <div class="ubicacion-bg"></div>
  <div class="ubicacion-accent-top"></div>
  <div class="ubicacion-accent-bottom"></div>
  <div class="container">
    <div class="section-header">
      <span class="section-tag">¡Visítanos!</span>
      <h2 class="section-title">Nuestra Ubicación</h2>
      <div class="section-line"></div>
      <p class="section-subtitle">Te esperamos en nuestro local</p>
    </div>

    <div class="ubicacion-wrapper">
      <div class="ubicacion-main">
        <div class="mapa-frame">
          <div class="mapa-inner">
            <iframe 
              src={GOOGLE_MAPS_URL}
              width="100%" 
              height="100%" 
              style="border:0;" 
              allowfullscreen="" 
              loading="lazy" 
              referrerpolicy="no-referrer-when-downgrade"
              title="Ubicación de la tienda"
            ></iframe>
          </div>
          <div class="mapa-glow"></div>
        </div>
      </div>

      <div class="ubicacion-details">
        <a href="https://www.google.com/maps/search/?api=1&query=Villa+del+Parque+CABA" target="_blank" rel="noopener noreferrer" class="detail-card-link">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Dirección</h3>
            <p>{DIRECCION}</p>
          </div>
        </a>

        <div class="detail-card">
          <div class="detail-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
          </div>
          <div class="detail-content">
            <h3>Horario</h3>
            <p>{HORARIO}</p>
          </div>
        </div>

        <div class="whatsapp-dropdown">
          <button class="whatsapp-toggle" id="whatsappToggle">
            <div class="detail-icon">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="detail-content">
              <h3>WhatsApp</h3>
              <p>Chateá con nosotros</p>
            </div>
            <svg class="dropdown-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="whatsapp-options" id="whatsappOptions">
            {whatsappOptions.map((opt) => (
              <a href={`https://wa.me/${opt.number}`} target="_blank" rel="noopener noreferrer" class="whatsapp-option">
                <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <span>{opt.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ubicacion {
    position: relative;
    padding: 5rem 2rem;
    overflow: hidden;
  }

  .ubicacion-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, #0d0d0d 0%, #151515 50%, #0d0d0d 100%);
    z-index: -1;
  }

  .ubicacion-accent-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.2), transparent);
    z-index: -1;
  }

  .ubicacion-accent-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
    z-index: -1;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: #c9a227;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: var(--font-title);
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1rem 0;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .section-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, #d4af37, #f5a623);
    margin: 0 auto;
    border-radius: 2px;
  }

  .section-subtitle {
    font-family: var(--font-subtitle);
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 1rem 0 0 0;
    font-style: italic;
  }

  .ubicacion-wrapper {
    display: flex;
    gap: 2.5rem;
    align-items: stretch;
  }

  .ubicacion-main {
    flex: 0 0 55%;
  }

  .mapa-frame {
    position: relative;
    height: 380px;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(212, 175, 55, 0.08);
    border: 1px solid rgba(212, 175, 55, 0.1);
  }

  .mapa-inner {
    width: 100%;
    height: 100%;
  }

  .mapa-inner iframe {
    width: 100%;
    height: 100%;
    filter: grayscale(30%) contrast(1.1) brightness(0.9);
  }

  .mapa-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.05) 0%, transparent 50%, rgba(245, 166, 35, 0.03) 100%);
    pointer-events: none;
  }

  .ubicacion-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .detail-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.8) 0%, rgba(13, 13, 13, 0.9) 100%);
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.08);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s ease;
  }

  .detail-card:hover {
    transform: translateY(-3px);
    border-color: rgba(212, 175, 55, 0.2);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(212, 175, 55, 0.1);
  }

  .detail-card-link {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.8) 0%, rgba(13, 13, 13, 0.9) 100%);
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.08);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s ease;
    text-decoration: none;
    color: inherit;
  }

  .detail-card-link:hover {
    transform: translateY(-3px);
    border-color: rgba(212, 175, 55, 0.2);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(212, 175, 55, 0.1);
  }

  .whatsapp-dropdown {
    position: relative;
  }

  .whatsapp-toggle {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    padding: 1.5rem;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.8) 0%, rgba(13, 13, 13, 0.9) 100%);
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.08);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    transition: all 0.4s ease;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    width: 100%;
  }

  .whatsapp-toggle:hover {
    transform: translateY(-3px);
    border-color: rgba(212, 175, 55, 0.2);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(212, 175, 55, 0.1);
  }

  .dropdown-arrow {
    margin-left: auto;
    margin-top: 0.5rem;
    transition: transform 0.3s ease;
  }

  .whatsapp-toggle.active .dropdown-arrow {
    transform: rotate(180deg);
  }

  .whatsapp-options {
    display: none;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.95) 0%, rgba(13, 13, 13, 0.95) 100%);
    border-radius: 8px;
    border: 1px solid rgba(212, 175, 55, 0.15);
    margin-top: 0.5rem;
    animation: slideDown 0.3s ease forwards;
  }

  .whatsapp-options.show {
    display: flex;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .whatsapp-option {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: rgba(42, 42, 42, 0.8);
    border-radius: 6px;
    text-decoration: none;
    color: #f5f5f5;
    transition: all 0.3s ease;
    font-size: 0.9rem;
  }

  .whatsapp-option:hover {
    background: rgba(212, 175, 55, 0.15);
    color: #d4af37;
  }

  .detail-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.15) 0%, rgba(245, 166, 35, 0.1) 100%);
    border-radius: 8px;
    flex-shrink: 0;
    border: 1px solid rgba(212, 175, 55, 0.2);
  }

  .detail-icon svg {
    width: 22px;
    height: 22px;
    color: #d4af37;
  }

  .detail-content h3 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: #c9a227;
    margin: 0 0 0.5rem 0;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .detail-content p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .ubicacion-wrapper {
      flex-direction: column;
    }

    .ubicacion-main {
      flex: none;
    }

    .mapa-frame {
      height: 300px;
    }
  }

  @media (max-width: 600px) {
    .ubicacion {
      padding: 3rem 1rem;
    }

    .section-title {
      font-size: 1.8rem;
    }

    .mapa-frame {
      height: 250px;
      border-radius: 6px;
    }

    .detail-card {
      padding: 1.25rem;
    }

    .detail-icon {
      width: 40px;
      height: 40px;
    }

    .detail-icon svg {
      width: 18px;
      height: 18px;
    }

    .detail-content h3 {
      font-size: 0.7rem;
    }

    .detail-content p {
      font-size: 0.85rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var toggle = document.getElementById('whatsappToggle');
    var options = document.getElementById('whatsappOptions');
    
    if (toggle && options) {
      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        toggle.classList.toggle('active');
        options.classList.toggle('show');
      });

      // Cerrar cuando se hace click fuera
      document.addEventListener('click', function(e) {
        var target = e.target;
        if (target && !toggle.contains(target) && !options.contains(target)) {
          toggle.classList.remove('active');
          options.classList.remove('show');
        }
      });
    }
  });
</script>
