---
import vinoImg from '../assets/productosDestacados/vino.jpg';
import champagneImg from '../assets/productosDestacados/champagne.jpg';
import whiskyImg from '../assets/productosDestacados/whisky.jpg';
import cervezaImg from '../assets/productosDestacados/cerveza.jpg';

const PRODUCTS = [
  {
    image: vinoImg.src,
    name: "Vinos Tintos Reserva",
    description: "Cabernet Sauvignon, Malbec y Merlot de las mejores cosechas."
  },
  {
    image: champagneImg.src,
    name: "Champagnes & Espumantes",
    description: "Champagne, Prosecco y Espumantes Brut y Demi-Sec."
  },
  {
    image: whiskyImg.src,
    name: "Whiskys Premium",
    description: "Scotch, Bourbon y Rye de ediciones selectas."
  },
  {
    image: cervezaImg.src,
    name: "Cervezas de Marcas",
    description: "Las mejores marcas nacionales e importadas."
  }
];

const SECTION_TITLE = "Catálogo de Productos";

const SECTION_SUBTITLE = "Las mejores bebidas para vos";
---

<section class="destacados">
  <div class="destacados-bg"></div>
  <div class="destacados-accent-top"></div>
  <div class="destacados-accent-bottom"></div>
  <div class="container">
    <div class="section-header">
      <span class="section-tag">{SECTION_SUBTITLE}</span>
      <h2 class="section-title">{SECTION_TITLE}</h2>
      <div class="section-line"></div>
    </div>
    
    <div class="products-grid">
      {PRODUCTS.map((product, index) => (
        <div class="product-card" style={`animation-delay: ${index * 0.15}s`}>
          <div class="product-image">
            <img src={product.image} alt={product.name} />
            <div class="product-glow"></div>
          </div>
          <div class="product-info">
            <h3 class="product-name">{product.name}</h3>
            <p class="product-description">{product.description}</p>
          </div>
        </div>
      ))}
    </div>
    
    <div class="section-cta">
      <a href="/tienda" class="view-all-btn">
        Ver Catálogo Completo
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .destacados {
    position: relative;
    padding: 5rem 2rem;
    overflow: hidden;
  }

  .destacados-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, #0d0d0d 0%, #151515 50%, #0d0d0d 100%);
    z-index: -1;
  }

  .destacados-accent-top {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.2), transparent);
    z-index: -1;
  }

  .destacados-accent-bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(212, 175, 55, 0.3), transparent);
    z-index: -1;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-tag {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: #c9a227;
    letter-spacing: 2px;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .section-title {
    font-family: var(--font-title);
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1rem 0;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .section-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, #d4af37, #f5a623);
    margin: 0 auto;
    border-radius: 2px;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .product-card {
    background: linear-gradient(180deg, rgba(26, 26, 26, 0.8) 0%, rgba(13, 13, 13, 0.9) 100%);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(212, 175, 55, 0.05);
    transition: all 0.4s ease;
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
    border: 1px solid rgba(212, 175, 55, 0.08);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(212, 175, 55, 0.15);
    border-color: rgba(212, 175, 55, 0.2);
  }

  .product-image {
    position: relative;
    height: 200px;
    overflow: hidden;
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.5s ease, opacity 0.3s ease;
    opacity: 0.85;
    padding: 10px;
    box-sizing: border-box;
  }

  .product-card:hover .product-image img {
    transform: scale(1.08);
    opacity: 1;
  }

  .product-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.08) 0%, transparent 50%, rgba(245, 166, 35, 0.04) 100%);
    pointer-events: none;
  }

  .product-info {
    padding: 1.5rem;
    text-align: center;
  }

  .product-name {
    font-family: var(--font-title);
    font-size: 1.1rem;
    font-weight: 600;
    color: #ffffff;
    margin: 0 0 0.75rem 0;
    letter-spacing: 1px;
  }

  .product-description {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin: 0;
  }

  .section-cta {
    text-align: center;
  }

  .view-all-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: transparent;
    color: #d4af37;
    text-decoration: none;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 1rem 2rem;
    border-radius: 4px;
    border: 1px solid rgba(212, 175, 55, 0.4);
    transition: all 0.4s ease;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .view-all-btn svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .view-all-btn:hover {
    background: rgba(212, 175, 55, 0.12);
    border-color: #d4af37;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(212, 175, 55, 0.15);
  }

  .view-all-btn:hover svg {
    transform: translateX(5px);
  }

  @media (max-width: 992px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .destacados {
      padding: 3rem 1.5rem;
    }

    .section-title {
      font-size: 1.8rem;
    }

    .products-grid {
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .products-grid {
      grid-template-columns: 1fr;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .view-all-btn {
      padding: 0.85rem 1.5rem;
      font-size: 0.8rem;
    }
  }
</style>
