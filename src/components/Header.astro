---
import { clientConfig } from "../config/clientConfig";

const logo = clientConfig.brand.logo;
const CLIENT_LOGO = logo?.src || logo;
const CLIENT_COMPANY_NAME = clientConfig.brand.name;
const CLIENT_SLOGAN = clientConfig.brand.slogan;
---

<header class="header">
  <div class="header-bg"></div>
  <div class="header-accent"></div>
  <div class="bubbles">
    <span></span><span></span><span></span><span></span><span></span>
  </div>
  <div class="container">
    <div class="brand">
      <a href="/" class="logo-link">
        <img src={CLIENT_LOGO} alt={CLIENT_COMPANY_NAME} class="logo-img" />
      </a>
      <div class="brand-info">
        <h1 class="company-name">{CLIENT_COMPANY_NAME}</h1>
        <p class="slogan">{CLIENT_SLOGAN}</p>
      </div>
    </div>
    <div class="header-tagline">
      <span class="tagline-text">Calidad</span>
      <span class="tagline-divider">•</span>
      <span class="tagline-text">Variedad</span>
      <span class="tagline-divider">•</span>
      <span class="tagline-text">Sabor</span>
    </div>
  </div>
</header>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Cinzel:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap');
</style>

<style>
  .header {
    position: relative;
    overflow: hidden;
    min-height: 200px;
  }

  .header-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(180deg, #0d0d0d 0%, #1a1a1a 50%, #1f1f1f 100%);
    z-index: -3;
  }

  .header-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #d4af37 0%, #f5a623 50%, #d4af37 100%);
    z-index: -1;
  }

  .bubbles {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -2;
    overflow: hidden;
  }

  .bubbles span {
    position: absolute;
    bottom: -100px;
    width: 30px;
    height: 30px;
    background: radial-gradient(circle at 30% 30%, rgba(212, 175, 55, 0.15), rgba(245, 166, 35, 0.05));
    border-radius: 50%;
    animation: rise 12s infinite ease-in;
  }

  .bubbles span:nth-child(1) { left: 10%; width: 40px; height: 40px; animation-delay: 0s; }
  .bubbles span:nth-child(2) { left: 25%; width: 20px; height: 20px; animation-delay: 2s; }
  .bubbles span:nth-child(3) { left: 45%; width: 35px; height: 35px; animation-delay: 4s; }
  .bubbles span:nth-child(4) { left: 65%; width: 25px; height: 25px; animation-delay: 1s; }
  .bubbles span:nth-child(5) { left: 85%; width: 30px; height: 30px; animation-delay: 3s; }

  @keyframes rise {
    0% { bottom: -100px; opacity: 0; }
    10% { opacity: 0.6; }
    50% { opacity: 0.4; }
    100% { bottom: 100%; opacity: 0; }
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .logo-img {
    height: 180px;
    width: auto;
    object-fit: contain;
    filter: drop-shadow(0 2px 10px rgba(212, 175, 55, 0.3));
  }

  .logo-link {
    display: block;
  }

  .brand-info {
    display: flex;
    flex-direction: column;
    border-left: 2px solid #d4af37;
    padding-left: 1.5rem;
  }

  .company-name {
    font-family: 'Cinzel', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin: 0;
    background: linear-gradient(180deg, #ffffff 0%, #d4af37 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .slogan {
    font-family: var(--font-subtitle);
    font-size: 1.1rem;
    font-weight: 400;
    color: #c9a227;
    letter-spacing: 2px;
    margin: 0.5rem 0 0 0;
    text-transform: uppercase;
  }

  .header-tagline {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tagline-text {
    font-family: var(--font-subtitle);
    font-size: 0.9rem;
    font-weight: 500;
    color: #888;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .tagline-divider {
    color: #d4af37;
    font-size: 0.75rem;
  }

  /* MOBILE (< 768px) */
  @media (max-width: 768px) {
    .header {
      min-height: 180px;
    }

    .container {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem 1rem;
    }

    .brand {
      flex-direction: column;
      text-align: center;
    }

    .logo-img {
      height: 120px;
    }

    .brand-info {
      border-left: none;
      border-top: 2px solid #d4af37;
      padding-left: 0;
      padding-top: 1rem;
    }

    .company-name {
      font-size: 1.8rem;
      letter-spacing: 2px;
    }

    .slogan {
      font-size: 0.85rem;
    }

    .header-tagline {
      display: none;
    }

    .bubbles {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .logo-img {
      height: 100px;
    }

    .company-name {
      font-size: 1.5rem;
    }

    .slogan {
      font-size: 0.75rem;
    }
  }
</style>
