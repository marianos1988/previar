---
// ====================================================
// CONFIGURACIÓN DEL CLIENTE - EDITAR AQUÍ
// ====================================================

// MENSAJE PREDEFINIDO (opcional)
const WHATSAPP_MESSAGE = "Hola! Me gustaría más información sobre sus productos.";

const whatsappContacts = [
  { number: "5491130552110", name: "Alejandro" },
  { number: "5491123233335", name: "Mariano" },
  { number: "5491123961837", name: "Diego" }
];

// ====================================================
---

<div class="whatsapp-container">
  <button type="button" class="whatsapp-btn" id="whatsappFabBtn" aria-label="Abrir opciones de WhatsApp">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.974 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
    <span class="whatsapp-tooltip">¡Escríbenos!</span>
  </button>
  
  <div class="whatsapp-options" id="whatsappFabOptions">
    {whatsappContacts.map((contact) => (
      <a 
        href={`https://wa.me/${contact.number}?text=${encodeURIComponent(WHATSAPP_MESSAGE)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="whatsapp-option"
      >
        <div class="option-avatar">
          <span>{contact.name.charAt(0)}</span>
        </div>
        <div class="option-info">
          <span class="option-name">{contact.name}</span>
          <span class="option-number">{contact.number.replace('549', '')}</span>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .whatsapp-container {
    position: fixed;
    bottom: 25px;
    right: 25px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  .whatsapp-btn {
    position: relative;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    border-radius: 50%;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.4);
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .whatsapp-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 10px 30px rgba(37, 211, 102, 0.5);
  }

  .whatsapp-btn svg {
    width: 28px;
    height: 28px;
    color: white;
    transition: all 0.3s ease;
  }

  .whatsapp-btn.active {
    transform: scale(0.95);
  }

  .whatsapp-btn.active svg {
    transform: rotate(90deg);
  }

  .whatsapp-tooltip {
    position: absolute;
    right: calc(100% + 15px);
    top: 50%;
    transform: translateY(-50%);
    background: white;
    color: #128C7E;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.15);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .whatsapp-tooltip::after {
    content: '';
    position: absolute;
    right: -8px;
    top: 50%;
    transform: translateY(-50%);
    border: 8px solid transparent;
    border-left-color: white;
  }

  .whatsapp-btn:hover .whatsapp-tooltip {
    opacity: 1;
    visibility: visible;
  }

  .whatsapp-options {
    display: none;
    flex-direction: column;
    gap: 8px;
    min-width: 220px;
    animation: slideUp 0.3s ease;
  }

  .whatsapp-options.show {
    display: flex;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .whatsapp-option {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
    border-radius: 16px;
    border: 1px solid rgba(212, 175, 55, 0.15);
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .whatsapp-option:hover {
    transform: translateX(-5px);
    border-color: rgba(212, 175, 55, 0.3);
    box-shadow: 0 6px 25px rgba(212, 175, 55, 0.2);
  }

  .whatsapp-option:hover .option-avatar {
    background: linear-gradient(135deg, #d4af37 0%, #e5c76b 100%);
    color: #1a1a1a;
  }

  .whatsapp-option:hover .option-name {
    color: #d4af37;
  }

  .option-avatar {
    width: 40px;
    height: 40px;
    min-width: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Cinzel', serif;
    font-weight: 600;
    font-size: 1rem;
    color: white;
    transition: all 0.3s ease;
  }

  .option-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .option-name {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 600;
    color: #f5f5f5;
    transition: all 0.3s ease;
  }

  .option-number {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(212, 175, 55, 0.8);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .whatsapp-container {
      bottom: 20px;
      right: 20px;
    }

    .whatsapp-btn {
      width: 55px;
      height: 55px;
    }

    .whatsapp-btn svg {
      width: 26px;
      height: 26px;
    }

    .whatsapp-btn:hover {
      transform: scale(1.05);
    }

    .whatsapp-tooltip {
      display: none;
    }

    .whatsapp-options {
      position: fixed;
      bottom: 85px;
      right: 20px;
      left: 20px;
      min-width: unset;
    }

    .whatsapp-option {
      padding: 14px;
    }
  }

  @media (max-width: 480px) {
    .whatsapp-container {
      bottom: 15px;
      right: 15px;
    }

    .whatsapp-btn {
      width: 50px;
      height: 50px;
    }

    .whatsapp-btn svg {
      width: 24px;
      height: 24px;
    }

    .whatsapp-options {
      right: 15px;
      left: 15px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var btn = document.getElementById('whatsappFabBtn');
    var options = document.getElementById('whatsappFabOptions');
    
    if (btn && options) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        btn.classList.toggle('active');
        options.classList.toggle('show');
      });

      document.addEventListener('click', function(e) {
        var target = e.target;
        if (target && !btn.contains(target) && !options.contains(target)) {
          btn.classList.remove('active');
          options.classList.remove('show');
        }
      });
    }
  });
</script>