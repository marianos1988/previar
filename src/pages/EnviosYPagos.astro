---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { clientConfig } from '../config/clientConfig';
import enviosImage from '../assets/enviosypagos/envios.png';

const { shipping, payment } = clientConfig;
---

<Layout title="Envíos y Pagos">
  <Header />
  <Navbar />
  
  <main>
    <section class="enviosYPagos">
      <div class="container">
        
        <!-- Módulo 1: Envíos -->
        <div class="module shipping-module">
          <div class="module-header">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"></rect>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
            </div>
            <div class="title-wrapper">
              <h2 class="module-title">{shipping.title}</h2>
              <p class="module-subtitle">{shipping.description}</p>
            </div>
          </div>
          
          <div class="shipping-content">
            <p class="section-intro">{shipping.subtitle}</p>
            <img src={enviosImage.src} alt="Zonas de Entrega" class="zones-map" />
            
            <div class="zones-grid">
              {shipping.zones.map((zone, index) => (
                <div class="zone-card">
                  <div class="zone-card-header">
                    <span class="zone-badge">Cordon {index + 1}</span>
                  </div>
                  <h3 class="zone-name">{zone.name}</h3>
                  <p class="zone-description">{zone.description}</p>
                  <div class="zone-price">
                    {zone.price === 0 ? (
                      <span class="price-pending">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <circle cx="12" cy="12" r="10"></circle>
                          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                          <line x1="12" y1="17" x2="12.01" y2="17"></line>
                        </svg>
                        Consultar precio
                      </span>
                    ) : (
                      <span class="price-value">
                        <span class="currency">$</span>{zone.price}
                      </span>
                    )}
                  </div>
                  <div class="zone-card-decoration"></div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Módulo 2: Formas de Pago -->
        <div class="module payment-module">
          <div class="module-header">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                <line x1="1" y1="10" x2="23" y2="10"></line>
              </svg>
            </div>
            <div class="title-wrapper">
              <h2 class="module-title">{payment.title}</h2>
              <p class="module-subtitle">{payment.description}</p>
            </div>
          </div>
          
          <div class="payment-content">
            <p class="section-intro">{payment.subtitle}</p>
            <div class="payment-methods">
              {payment.methods.map((method) => (
                <div class="payment-card">
                  <div class="payment-icon-large">
                    {method.name === "Transferencia" && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="1" x2="12" y2="23"></line>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                      </svg>
                    )}
                    {method.name === "Efectivo" && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="6" width="20" height="12" rx="2"></rect>
                        <circle cx="12" cy="12" r="2"></circle>
                        <path d="M6 12h.01M18 12h.01"></path>
                      </svg>
                    )}
                  </div>
                  <div class="payment-details">
                    <h3 class="payment-name">{method.name}</h3>
                    <p class="payment-detail">{method.description}</p>
                  </div>
                  <div class="payment-card-decoration"></div>
                </div>
              ))}
            </div>
            
            <div class="payment-note">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                <polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
              <span>El vendedor te enviará las opciones disponibles al confirmar tu pedido</span>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    min-height: calc(100vh - 200px);
    background: linear-gradient(135deg, #fdfbf5 0%, #faf5e8 100%);
  }

  .enviosYPagos {
    padding: 3rem 1.5rem;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .module {
    background: #0a0a0a;
    border-radius: 24px;
    padding: 2.5rem;
    box-shadow: 
      0 4px 20px rgba(212, 175, 55, 0.08),
      0 1px 3px rgba(0, 0, 0, 0.05);
    position: relative;
    overflow: hidden;
  }

  .module::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #d4af37, #e5c76b, #d4af37);
  }

  .module-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .icon-wrapper {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #d4af37 0%, #e5c76b 100%);
    border-radius: 16px;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
  }

  .icon-wrapper svg {
    color: #fff;
  }

  .zones-map {
    width: 100%;
    max-width: 600px;
    height: auto;
    border-radius: 12px;
    margin: 1.5rem auto;
    display: block;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .zones-map {
      max-width: 100%;
      margin: 1rem 0;
    }
  }

  @media (max-width: 480px) {
    .zones-map {
      max-width: 100%;
      margin: 0.75rem 0;
    }
  }

  .title-wrapper {
    flex: 1;
  }

  .module-title {
    font-family: 'Cinzel', serif;
    font-size: 1.85rem;
    color: #f5f5f5;
    margin: 0 0 0.5rem 0;
    font-weight: 600;
  }

  .module-subtitle {
    color: #a0a0a0;
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
  }

  .section-intro {
    color: #f5f5f5;
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 1.5rem 0;
    padding-left: 1rem;
    border-left: 3px solid #d4af37;
  }

  /* Shipping Module */
  .zones-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .zone-card {
    background: #1a1a1a;
    border: 1px solid rgba(212, 175, 55, 0.12);
    border-radius: 16px;
    padding: 1.25rem;
    text-align: center;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .zone-card:hover {
    transform: translateY(-4px);
    border-color: #d4af37;
    box-shadow: 
      0 12px 24px rgba(212, 175, 55, 0.15),
      0 4px 8px rgba(212, 175, 55, 0.1);
  }

  .zone-card-header {
    margin-bottom: 0.75rem;
  }

  .zone-badge {
    display: inline-block;
    background: linear-gradient(135deg, #d4af37 0%, #e5c76b 100%);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .zone-card h3 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    color: #f5f5f5;
    margin: 0 0 0.4rem 0;
  }

  .zone-description {
    color: #a0a0a0;
    font-size: 0.8rem;
    margin: 0 0 0.75rem 0;
  }

  .zone-price {
    font-weight: 600;
  }

  .price-value {
    color: #d4af37;
    font-size: 1.3rem;
    font-weight: 700;
  }

  .price-value .currency {
    font-size: 0.9rem;
    margin-right: 2px;
  }

  .price-pending {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    color: #b8a888;
    font-size: 0.85rem;
    font-style: italic;
  }

  .zone-card-decoration {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .zone-card:hover .zone-card-decoration {
    opacity: 1;
  }

  /* Payment Module */
  .payment-methods {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .payment-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: #1a1a1a;
    border: 1px solid rgba(212, 175, 55, 0.12);
    border-radius: 16px;
    padding: 1.5rem 2rem;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }

  .payment-card:hover {
    transform: translateY(-4px);
    border-color: #d4af37;
    box-shadow: 
      0 12px 24px rgba(212, 175, 55, 0.15),
      0 4px 8px rgba(212, 175, 55, 0.1);
  }

  .payment-icon-large {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #d4af37 0%, #e5c76b 100%);
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 4px 16px rgba(212, 175, 55, 0.3);
  }

  .payment-icon-large svg {
    color: #fff;
  }

  .payment-details {
    flex: 1;
  }

  .payment-details h3 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    color: #f5f5f5;
    margin: 0 0 0.35rem 0;
  }

  .payment-details p {
    color: #a0a0a0;
    font-size: 0.95rem;
    margin: 0;
  }

  .payment-card-decoration {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, #d4af37, transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .payment-card:hover .payment-card-decoration {
    opacity: 1;
  }

  .payment-note {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: #1a1a1a;
    border-radius: 12px;
    border: 1px dashed rgba(212, 175, 55, 0.2);
  }

  .payment-note svg {
    color: #d4af37;
    flex-shrink: 0;
  }

  .payment-note span {
    color: #a0a0a0;
    font-size: 0.9rem;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .zones-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .enviosYPagos {
      padding: 2rem 1rem;
    }

    .module {
      padding: 1.75rem;
    }

    .module-title {
      font-size: 1.5rem;
    }

    .zones-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .zone-card {
      padding: 1rem;
    }
  }

  @media (max-width: 480px) {
    .module-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .icon-wrapper {
      width: 48px;
      height: 48px;
    }

    .icon-wrapper svg {
      width: 22px;
      height: 22px;
    }

    .module-title {
      font-size: 1.35rem;
    }

    .zones-grid {
      grid-template-columns: 1fr;
    }

    .zone-card {
      text-align: center;
    }

    .zone-card-header {
      display: flex;
      justify-content: center;
    }

    .payment-note {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
